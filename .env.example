# --- LLM provider (default: openai) ---
# LLM_PROVIDER=openai

# OpenAI (direct) — when LLM_PROVIDER is unset or openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# Azure OpenAI Responses — when LLM_PROVIDER=azure
# Deployment name is sent as the Responses `model` field.
#
# Pattern A — legacy resource root (Cognitive Services or openai.azure.com without /openai/v1):
#   AZURE_OPENAI_API_VERSION is required (e.g. 2025-04-01-preview).
# AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_API_VERSION=2025-04-01-preview
# AZURE_OPENAI_DEPLOYMENT=gpt-5.4-mini
#
# Pattern B — OpenAI v1 base URL (no extra /openai suffix; do NOT set API version — Azure rejects api-version on v1):
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/openai/v1/
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_DEPLOYMENT=gpt-5.4-mini

# --- API persistence ---
# Default local backend:
# DATABASE_DRIVER=sqlite
# DATABASE_PATH=./signalforge.db
#
# Postgres backend:
# DATABASE_DRIVER=postgres
# DATABASE_URL=postgres://user:password@host:5432/signalforge

# --- Phase 6c: operator API + Sources UI (required for /api/sources, /api/collection-jobs/*, /api/agent/registrations) ---
# Long random secret. Browser UI uses /sources/login (httpOnly cookie); curl uses Authorization: Bearer <token>
# SIGNALFORGE_ADMIN_TOKEN=
