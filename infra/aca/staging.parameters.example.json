{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": {
      "value": "eastus2"
    },
    "containerAppName": {
      "value": "ca-signalforge-staging"
    },
    "containerAppsEnvironmentId": {
      "value": "/subscriptions/<subscription-id>/resourceGroups/<resource-group>/providers/Microsoft.App/managedEnvironments/<aca-environment>"
    },
    "image": {
      "value": "ghcr.io/canepro/signalforge:<release-tag>"
    },
    "registryServer": {
      "value": ""
    },
    "registryIdentityResourceId": {
      "value": ""
    },
    "cpu": {
      "value": "0.5"
    },
    "memory": {
      "value": "1Gi"
    },
    "minReplicas": {
      "value": 0
    },
    "maxReplicas": {
      "value": 3
    },
    "databaseUrl": {
      "value": "postgres://<user>:<password>@<neon-host>/<database>?sslmode=require"
    },
    "signalforgeAdminToken": {
      "value": "<long-random-secret>"
    },
    "llmProvider": {
      "value": ""
    },
    "openAiApiKey": {
      "value": ""
    },
    "openAiModel": {
      "value": "gpt-5-mini"
    },
    "azureOpenAiEndpoint": {
      "value": ""
    },
    "azureOpenAiApiKey": {
      "value": ""
    },
    "azureOpenAiDeployment": {
      "value": ""
    },
    "azureOpenAiApiVersion": {
      "value": ""
    },
    "revisionSuffix": {
      "value": "<revision-suffix>"
    },
    "tags": {
      "value": {
        "app": "signalforge",
        "surface": "aca",
        "role": "app"
      }
    }
  }
}
