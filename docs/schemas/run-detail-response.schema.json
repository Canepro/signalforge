{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://signalforge.local/schemas/run-detail-response.schema.json",
  "title": "GET /api/runs/[id] success",
  "description": "Mirrors toRunDetailJson() / GetRunDetailResponse. Embedded report is full AuditReport JSON.",
  "type": "object",
  "required": [
    "id",
    "artifact_id",
    "parent_run_id",
    "links",
    "filename",
    "artifact_type",
    "source_type",
    "target_identifier",
    "source_label",
    "collector_type",
    "collector_version",
    "collected_at",
    "created_at",
    "status",
    "is_incomplete",
    "incomplete_reason",
    "analysis_error",
    "model_used",
    "tokens_used",
    "duration_ms",
    "severity_counts",
    "report",
    "environment",
    "noise",
    "pre_findings"
  ],
  "properties": {
    "id": { "type": "string" },
    "artifact_id": { "type": "string" },
    "parent_run_id": { "type": ["string", "null"] },
    "links": {
      "type": "object",
      "required": ["compare_ui", "compare_api"],
      "properties": {
        "compare_ui": { "type": "string" },
        "compare_api": { "type": "string" }
      },
      "additionalProperties": false
    },
    "filename": { "type": "string" },
    "artifact_type": { "type": "string" },
    "source_type": { "type": "string" },
    "target_identifier": { "type": ["string", "null"] },
    "source_label": { "type": ["string", "null"] },
    "collector_type": { "type": ["string", "null"] },
    "collector_version": { "type": ["string", "null"] },
    "collected_at": { "type": ["string", "null"] },
    "created_at": { "type": "string" },
    "status": { "type": "string" },
    "is_incomplete": { "type": "boolean" },
    "incomplete_reason": { "type": ["string", "null"] },
    "analysis_error": { "type": ["string", "null"] },
    "model_used": { "type": ["string", "null"] },
    "tokens_used": { "type": "number" },
    "duration_ms": { "type": "number" },
    "severity_counts": { "type": "object", "additionalProperties": { "type": "number" } },
    "report": { "type": ["object", "null"] },
    "environment": { "type": ["object", "null"] },
    "noise": { "type": ["array", "null"] },
    "pre_findings": { "type": ["array", "null"] }
  },
  "additionalProperties": false
}
