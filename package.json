{
  "name": "signalforge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "next typegen && tsc --noEmit -p tsconfig.typecheck.json",
    "test": "vitest run",
    "test:parity": "vitest run tests/storage/parity.test.ts",
    "test:watch": "vitest",
    "test:integration": "vitest run tests/analyzer",
    "analyze": "bun src/lib/analyzer/cli.ts",
    "db:migrate:postgres": "bun scripts/db-migrate-postgres.ts"
  },
  "dependencies": {
    "next": "^15.3.2",
    "openai": "^5.8.2",
    "pg": "^8.20.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sql.js": "^1.14.1",
    "zod": "^3.25.23"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.7",
    "@types/node": "^22.15.18",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "tailwindcss": "^4.1.7",
    "typescript": "^5.8.3",
    "vitest": "^3.2.1"
  }
}
